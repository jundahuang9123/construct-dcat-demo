PREFIX dcat: <http://www.w3.org/ns/dcat#>
PREFIX dct:  <http://purl.org/dc/terms/>
# Baseline DCAT/DCAT-AP discovery: best a consumer can do is match free text
# (title or keyword) against the query term.
SELECT ?d ?matchedText WHERE {
  ?d a dcat:Dataset .
  { ?d dct:title ?matchedText . }
  UNION
  { ?d dcat:keyword ?matchedText . }
  FILTER(CONTAINS(LCASE(STR(?matchedText)), "wall"))
}
